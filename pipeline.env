#!/usr/bin/env bash
# ============================================================
# pipeline.env
# Environment configuration for post-deployment health pipeline
#
# USAGE:
#   source pipeline.env && ./test-local.sh --live
#
# For GitLab: add these as CI/CD Variables (Settings → CI/CD → Variables)
# Mark sensitive values as "Masked" and "Protected"
# ============================================================

# ── Application identity (set per pipeline trigger) ──────────
export APP_NAME="my-app"
export NAMESPACE="my-app-prod"
export APP_VERSION="1.2.3"

# ── OpenShift ────────────────────────────────────────────────
# OCP_API_URL: oc whoami --show-server
# OCP_TOKEN:   oc whoami -t  (use a service account token, NOT your personal token)
export OCP_API_URL="https://api.your-cluster.example.com:6443"
export OCP_TOKEN="your-service-account-token-here"      # MASKED in GitLab

# ── AppDynamics ──────────────────────────────────────────────
# Create an API client under AppDynamics → Settings → API Clients
export APPD_CONTROLLER_URL="https://yourcompany.saas.appdynamics.com"
export APPD_API_KEY="your-appd-api-client-secret"       # MASKED in GitLab
export APPD_APP_NAME="MyApp-Production"                 # AppD application display name

# ── ELK / Elasticsearch ──────────────────────────────────────
export ELASTICSEARCH_URL="https://elasticsearch.yourcompany.com:9200"
# ELK_AUTH = base64("username:password")
# Generate: echo -n 'user:password' | base64
export ELK_AUTH="dXNlcjpwYXNzd29yZA=="                  # MASKED in GitLab
export ELK_INDEX="app-logs-prod-*"

# ── Thresholds (tune per application SLA) ────────────────────
export ERROR_RATE_THRESHOLD="5"        # % — AppDynamics error rate allowed
export RESPONSE_TIME_THRESHOLD="2000"  # ms — avg response time allowed
export LOG_ERROR_THRESHOLD="10"        # count of ERROR logs per 15 min
export HTTP_5XX_THRESHOLD="5"          # % 5xx HTTP responses allowed
export HTTP_SLOW_THRESHOLD="3000"      # ms — requests above this = "slow"
export MIN_READY_RATIO="100"           # % of pods that must be Ready

# ── Timing ───────────────────────────────────────────────────
export STABILIZE_WAIT="60"             # seconds to wait after deploy
export ROLLOUT_TIMEOUT="300"           # seconds to wait for rollout

# ── Optional: Slack notifications ────────────────────────────
# export SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."

# ── Optional: ServiceNow change ticket auto-close ────────────
# export SNOW_INSTANCE="yourcompany.service-now.com"
# export SNOW_API_USER="svc-deploy"
# export SNOW_API_PASS="..."
# export SNOW_CHANGE_ID="CHG0012345"
